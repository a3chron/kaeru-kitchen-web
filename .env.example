# --- Public (shipped to the browser) ---
NEXT_PUBLIC_SUPABASE_ANON_KEY="your_anon_key"
NEXT_PUBLIC_SUPABASE_URL="https://your_custom_url.supabase.co"

# --- Server-only: NEVER prefix with NEXT_PUBLIC ---
# Supabase service-role key (Project Settings -> API). Used by server routes/actions
# to perform privileged writes. Bypasses RLS, so it must never reach the client.
SUPABASE_SERVICE_ROLE_KEY="your_service_role_key"

# Postgres connection string used ONLY by Drizzle migrations (local/CI, not Vercel runtime).
# Use the Supabase "Session pooler" connection string (port 5432) — it is IPv4-safe and
# supports DDL. The direct connection (db.<ref>.supabase.co) is IPv6-only without the
# IPv4 add-on. Do NOT use the transaction pooler (port 6543) for migrations.
DATABASE_URL="postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres"

# Rate limiting (optional). If unset, rate limiting is disabled with a warning.
# Provision via the Upstash Vercel integration or an Upstash Redis database.
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# Bearer token guarding GET /api/get-flagged-recipes (moderation). Generate with
# `openssl rand -hex 32`. If unset, that route fails closed (503).
MODERATION_API_KEY=""

# Salt for hashing client IPs used in review/flag dedup. Generate with `openssl rand -hex 32`.
IP_HASH_SALT=""
